-- =========================
-- AUTO SKILL
-- =========================

task.spawn(function()
	while task.wait() do
		if _G.AutoFarm
		and _G.AutoSkill
		and target
		and not Paused then
			Skill1()
			task.wait(1)
			Skill2()
			task.wait(1)
			Skill3()
			task.wait(1)
			SkillF()
			task.wait(1)
		end
	end
end)

-- =========================
-- AUTO AWAKEN
-- =========================

task.spawn(function()
	while task.wait() do
		if _G.AutoFarm
		and _G.AutoAwaken then
			if player:FindFirstChild("Awakening")
			and player.Awakening.Value >= 200 then
				Paused = true
				task.wait(1)
				Awakening()
				task.wait(2)
				Paused = false
			end
		end
	end
end)

-- =========================
-- AUTO REPLAY
-- =========================

task.spawn(function()

	player.PlayerGui.ChildAdded:Connect(function(gui)

		if _G.AutoReplay then

			if gui.Name == "EndScreen"
			or gui.Name == "EndScreenFail" then

				task.wait(2)

				EndBridge:Fire(1)

			end
		end
	end)

end)

-- =========================
-- MAIN FARM
-- =========================

task.spawn(function()
	while task.wait() do
		if _G.AutoFarm then
			if not target
			or not target.Parent
			or not target:FindFirstChild("Humanoid")
			or target.Humanoid.Health <= 0 then
				target = nil
				for _, mob in pairs(workspace.NPCs:GetChildren()) do
					if mob:FindFirstChild("Humanoid")
					and mob:FindFirstChild("HumanoidRootPart")
					and mob.Humanoid.Health > 0 then
						target = mob
						break
					end
				end
			end
			if target and not Paused then
				local mobhrp = target.HumanoidRootPart
				local pos = mobhrp.Position + Vector3.new(0, FarmHeight, 0)
				hrp.CFrame = CFrame.new(pos, mobhrp.Position)
				hrp.AssemblyLinearVelocity = Vector3.zero
				hrp.AssemblyAngularVelocity = Vector3.zero
				local args = {
					[1] = {
						[1] = {
							["state"] = Enum.HumanoidStateType.Running,
							["hitcount"] = combo
						},
						[2] = "\12"
					}
				}
				remote:FireServer(unpack(args))
				combo += 1
				if combo > 4 then
					combo = 1
				end
			end
		end
	end
end)

