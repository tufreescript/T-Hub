local function Awakening()

	if player:FindFirstChild("Awakening")
	and player.Awakening.Value >= 200 then
		if not char:GetAttribute("stunned")
		and not char:GetAttribute("Cant") then
			AwakenBridge:Fire()
		end
	end
end

